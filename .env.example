# Copy to .env and fill in. .env is gitignored.

# Required: OpenRouter API key used for message classification.
OPENROUTER_API_KEY=

# Optional: Pushover credentials. Only needed if notifications.pushover is true in config.json.
PUSHOVER_APP_TOKEN=
PUSHOVER_USER_KEY=

# Optional: successful non-dry-run scans send a GET request to this secret check-in URL.
DEAD_MANS_SNITCH_URL=
